{
  "name": "doppelshield",
  "version": "1.1.0",
  "description": "URL forensics tool that decodes the host, flags look-alike characters, and traces the redirect chain to surface homograph attacks.",
  "private": true,
  "license": "Apache-2.0",
  "author": "Joe Maalouf",
  "homepage": "https://github.com/joelouf/doppelshield#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joelouf/doppelshield.git"
  },
  "bugs": {
    "url": "https://github.com/joelouf/doppelshield/issues"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "npm@11.17.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "gen:targets": "node scripts/gen-brand-targets.mjs"
  },
  "dependencies": {
    "@formspree/react": "^3.0.0",
    "next": "^16.2.10",
    "punycode": "^2.3.1",
    "react": "^19",
    "react-dom": "^19",
    "react-icons": "^5.7.0",
    "uuid": "^14.0.1",
    "validator": "^13.15.35"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.10",
    "@types/node": "^24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.5",
    "typescript": "^6",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "^8.5.16"
  }
}
