# Public canonical site URL (build & metadata).
NEXT_PUBLIC_SITE_URL=https://doppelshield.com

# Runtime.
NODE_ENV=production
PORT=3000

# checkUrl engine tunables.
# Optional with defaults shown below.
CHECKURL_TIMEOUT_MS=5000
CHECKURL_TOTAL_DEADLINE_MS=10000
CHECKURL_MAX_REDIRECTS=3
CHECKURL_MAX_URL_LENGTH=2048
CHECKURL_ALLOWED_PORTS=80,443
CHECKURL_USER_AGENT=DoppelShieldBot/1.0 (+https://doppelshield.com/bot)
CHECKURL_MAX_SOCKETS=64
CHECKURL_MAX_CONCURRENT_SCANS=50
CHECKURL_MAX_BODY_BYTES=8192

# Trusted client-IP header for per-client rate limiting.
# REQUIRED behind a proxy or CDN.
# If unset, all clients share one global rate-limit bucket, so a single visitor can rate-limit everyone.
# Set to header that the edge sets and overwrites:
#   - Vercel: x-vercel-forwarded-for
#   - Cloudflare: cf-connecting-ip
#   - nginx: x-real-ip
# Do not point at raw, client-appendable x-forwarded-for on bare origin.
CHECKURL_TRUSTED_IP_HEADER=

CHECKURL_RATE_LIMIT_MAX=20
CHECKURL_RATE_LIMIT_WINDOW_MS=60000
CHECKURL_MIN_RESPONSE_MS=500
